<?xml version="1.0" encoding="UTF-8"?>
<actions>
    <action>
        <actionName>run</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.5.0:java</goal>
        </goals>
        <properties>
            <exec.vmArgs>--enable-native-access=ALL-UNNAMED</exec.vmArgs>
            <exec.args></exec.args>
        </properties>
    </action>
    <action>
        <actionName>debug</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.5.0:java</goal>
        </goals>
        <properties>
            <exec.vmArgs>--enable-native-access=ALL-UNNAMED -agentlib:jdwp=transport=dt_socket,server=n,address=${jpda.address}</exec.vmArgs>
            <exec.args></exec.args>
            <jpda.listen>true</jpda.listen>
        </properties>
    </action>
    <action>
        <actionName>run.single</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.5.0:java</goal>
        </goals>
        <properties>
            <exec.vmArgs>--enable-native-access=ALL-UNNAMED</exec.vmArgs>
            <exec.mainClass>${packageClassName}</exec.mainClass>
            <exec.args></exec.args>
        </properties>
    </action>
    <action>
        <actionName>debug.single</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.5.0:java</goal>
        </goals>
        <properties>
            <exec.vmArgs>--enable-native-access=ALL-UNNAMED -agentlib:jdwp=transport=dt_socket,server=n,address=${jpda.address}</exec.vmArgs>
            <exec.mainClass>${packageClassName}</exec.mainClass>
            <exec.args></exec.args>
            <jpda.listen>true</jpda.listen>
        </properties>
    </action>
</actions>
